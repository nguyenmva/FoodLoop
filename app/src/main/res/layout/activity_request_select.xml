<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fff6d7">

    <ImageView
        android:id="@+id/imageView8"
        android:layout_width="53dp"
        android:layout_height="46dp"
        android:layout_gravity="center"
        android:contentDescription="@string/imgFoodLoopLogo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.03"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.059"
        app:srcCompat="@drawable/foodloop_logo" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tvRecylerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@+id/btnReqItemToHome"
        app:layout_constraintTop_toBottomOf="@+id/inputReqItem"
        app:layout_constraintVertical_bias="1.0"
        tools:layout_editor_absoluteX="0dp" />

    <TextView
        android:id="@+id/txtFoodRequest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/txtFoodReqTitle"
        android:textColor="#ff193b"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.138" />

    <EditText
        android:id="@+id/inputReqItem"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="176dp"
        android:layout_marginEnd="10dp"
        android:background="@android:color/white"
        android:hint="@string/txtInputReqItem"
        android:inputType="text"
        android:paddingStart="15dp"
        app:layout_constraintEnd_toStartOf="@+id/imgMagGlass"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/imgMagGlass"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/magnifying_glass"
        android:contentDescription="@string/imgDesc"
        android:src="@drawable/magnifying_glass"
        app:layout_constraintBottom_toBottomOf="@+id/inputReqItem"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/inputReqItem"
        app:layout_constraintVertical_bias="1.0" />

    <Button
        android:id="@+id/btnReqItemToHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:backgroundTint="#ff193b"
        android:text="@string/btnHome"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>