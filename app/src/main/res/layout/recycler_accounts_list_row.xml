<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"> <!-- change from match_parent -->

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardElevation="4dp"
        app:cardCornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/row_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="name"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/row_street"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="street"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/row_city"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="city"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/row_province"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="province"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/row_country"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="country"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/row_postal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="postal"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/row_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="phone"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/row_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="email"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/row_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="password"
                android:textSize="15sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>