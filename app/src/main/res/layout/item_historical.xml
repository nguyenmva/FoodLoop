<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/txtItem"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#AB1212"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/txtStatus"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/txtLocation"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvDateRequested"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/txtDateReq"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvRequestor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/txtRequestor"
        android:textSize="15sp" />

</LinearLayout>