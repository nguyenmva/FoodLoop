<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="@string/txtItem"
            android:textColor="#555555"
            android:textSize="15sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txtItem"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#AB1212"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/statusRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="@string/txtStatus"
            android:textColor="#555555"
            android:textSize="15sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Status"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="@string/txtLocation"
            android:textColor="#555555"
            android:textSize="15sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txtLocation"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/requestorRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="@string/txtRequestor"
            android:textColor="#555555"
            android:textSize="15sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvRequestor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txtRequestor"
            android:textSize="15sp" />

    </LinearLayout>

</LinearLayout>